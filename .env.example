# Copy this file to .env and fill in the values. Never commit .env.

# ── LLM backend ──────────────────────────────────────────────
# "openai" for demo, "vllm" for on-premise production
LLM_BACKEND=openai

# OpenAI (used when LLM_BACKEND=openai)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# vLLM (used when LLM_BACKEND=vllm)
# vLLM exposes an OpenAI-compatible API, so the client shape is the same.
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# ── Embedding model (always local) ───────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3

# ── Neo4j ────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me

# ── FastAPI ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ── Company identity (used in UI and standards) ──────────────
COMPANY_NAME=코리아스틸
